<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Tell Us About You</title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --yellow: #FFE135;
      --pink:   #FF3CAC;
      --blue:   #2B86C5;
      --dark:   #0D0D0D;
      --white:  #FFFFFF;
    }

    body {
      min-height: 100vh;
      background: var(--dark);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'DM Sans', sans-serif;
      padding: 2rem;
      background-image:
        radial-gradient(ellipse at top left,  #FF3CAC33 0%, transparent 50%),
        radial-gradient(ellipse at bottom right, #2B86C533 0%, transparent 50%);
    }

    .card {
      background: #161616;
      border: 2px solid #2a2a2a;
      border-radius: 20px;
      padding: 3rem 2.5rem;
      width: 100%;
      max-width: 460px;
      position: relative;
      overflow: hidden;
    }

    .card::before {
      content: '';
      position: absolute;
      top: -2px; left: -2px; right: -2px; bottom: -2px;
      border-radius: 22px;
      background: linear-gradient(135deg, var(--pink), var(--yellow), var(--blue));
      z-index: -1;
    }

    .badge {
      display: inline-block;
      background: var(--yellow);
      color: var(--dark);
      font-family: 'Syne', sans-serif;
      font-size: 0.7rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 4px 12px;
      border-radius: 100px;
      margin-bottom: 1.2rem;
    }

    h1 {
      font-family: 'Syne', sans-serif;
      font-size: 2.2rem;
      font-weight: 800;
      color: var(--white);
      line-height: 1.1;
      margin-bottom: 0.5rem;
    }

    h1 span {
      background: linear-gradient(90deg, var(--pink), var(--yellow));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    p.sub {
      color: #888;
      font-size: 0.92rem;
      margin-bottom: 2rem;
    }

    .field {
      margin-bottom: 1.2rem;
    }

    label {
      display: block;
      font-size: 0.78rem;
      font-weight: 500;
      color: #aaa;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 6px;
    }

    input, select {
      width: 100%;
      background: #1f1f1f;
      border: 1.5px solid #2e2e2e;
      border-radius: 10px;
      color: var(--white);
      font-family: 'DM Sans', sans-serif;
      font-size: 0.95rem;
      padding: 0.75rem 1rem;
      outline: none;
      transition: border-color 0.2s;
    }

    input:focus, select:focus {
      border-color: var(--pink);
    }

    select option { background: #1f1f1f; }

    .row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }

    button {
      width: 100%;
      margin-top: 1.6rem;
      padding: 0.9rem;
      border: none;
      border-radius: 12px;
      background: linear-gradient(135deg, var(--pink), var(--yellow));
      color: var(--dark);
      font-family: 'Syne', sans-serif;
      font-size: 1rem;
      font-weight: 800;
      cursor: pointer;
      letter-spacing: 0.04em;
      transition: transform 0.15s, opacity 0.15s;
    }

    button:hover  { transform: translateY(-2px); opacity: 0.92; }
    button:active { transform: translateY(0);    opacity: 1; }

    .success {
      display: none;
      text-align: center;
      padding: 1.5rem 0 0;
    }

    .success .emoji { font-size: 2.5rem; }

    .success p {
      color: var(--yellow);
      font-family: 'Syne', sans-serif;
      font-size: 1.1rem;
      font-weight: 700;
      margin-top: 0.5rem;
    }

    .success small { color: #666; font-size: 0.82rem; }
  </style>
</head>
<body>
  <div class="card">
    <div class="badge">✦ Quick Form</div>
    <h1>Tell us about <span>yourself.</span></h1>
    <p class="sub">Fill in the details below — takes 30 seconds.</p>

    <div class="field row">
      <div>
        <label>First Name</label>
        <input type="text" id="fname" placeholder="Alex" />
      </div>
      <div>
        <label>Last Name</label>
        <input type="text" id="lname" placeholder="Smith" />
      </div>
    </div>

    <div class="field">
      <label>Email</label>
      <input type="email" id="email" placeholder="alex@email.com" />
    </div>

    <div class="field">
      <label>Phone</label>
      <input type="tel" id="phone" placeholder="+91 98765 43210" />
    </div>

    <div class="field row">
      <div>
        <label>Age</label>
        <input type="number" id="age" placeholder="24" min="1" max="120" />
      </div>
      <div>
        <label>Gender</label>
        <select id="gender">
          <option value="">Select</option>
          <option>Male</option>
          <option>Female</option>
          <option>Non-binary</option>
          <option>Prefer not to say</option>
        </select>
      </div>
    </div>

    <div class="field">
      <label>City</label>
      <input type="text" id="city" placeholder="Mumbai" />
    </div>

    <button onclick="submit()">Submit →</button>

    <div class="success" id="success">
      <div class="emoji">🎉</div>
      <p>You're all set!</p>
      <small>Thanks for sharing your info.</small>
    </div>
  </div>

  <script>
    function submit() {
      const fields = ['fname','lname','email','phone','age','gender','city'];
      const empty = fields.filter(id => !document.getElementById(id).value.trim());
      if (empty.length) {
        empty.forEach(id => {
          const el = document.getElementById(id);
          el.style.borderColor = '#FF3CAC';
          el.addEventListener('input', () => el.style.borderColor = '', { once: true });
        });
        return;
      }
      document.querySelector('button').style.display = 'none';
      document.getElementById('success').style.display = 'block';
    }
  </script>
</body>
</html>
